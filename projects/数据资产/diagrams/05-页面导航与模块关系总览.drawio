        <mxCell id="p1-title" value="&lt;b&gt;资产模版 page-templates&lt;/b&gt; · 核心页面" style="text;html=1;strokeColor=none;fillColor=#E8F5E9;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="390" y="115" width="440" height="26" as="geometry" />
        </mxCell>
        <mxCell id="p1-detail" value="&lt;b&gt;功能：&lt;/b&gt;&lt;br&gt;• 模板列表表格 (renderTemplateTable)&lt;br&gt;• 新建/编辑/删除模板&lt;br&gt;• 跳转 → page-template-edit (两个Tab)&lt;br&gt;  - Tab1: 基础信息 (名称/类型/台账字段/编码规则)&lt;br&gt;  - Tab2: 树形结构 (左右分栏编辑)&lt;br&gt;    · 统一模式: +下级/平级 → 选择节点类型&lt;br&gt;    · 经典模式: +下级/+平级/删除按钮&lt;br&gt;• 复制/粘贴分支" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="396" y="147" width="428" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p1-vars" value="&lt;b&gt;关联变量：&lt;/b&gt;templates[], editingTemplateId, selectedTreeNodeId, templateTreeCollapsed, isNewTemplateFlow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F1F8E9;strokeColor=none;fontSize=8;align=left;spacingLeft=6;fontColor=#558B2F;" vertex="1" parent="1">
          <mxGeometry x="396" y="265" width="428" height="35" as="geometry" />
        </mxCell>

