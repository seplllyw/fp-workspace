        </mxCell>
        <mxCell id="p2-title" value="&lt;b&gt;在管资产 page-instances&lt;/b&gt; · 核心页面" style="text;html=1;strokeColor=none;fillColor=#E3F2FD;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="870" y="115" width="460" height="26" as="geometry" />
