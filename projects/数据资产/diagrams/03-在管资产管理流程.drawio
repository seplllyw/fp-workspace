        <mxCell id="inst-edit-btn" value="&lt;b&gt;查看/编辑实例&lt;/b&gt;&lt;br&gt;数字档案 + 台账信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#90CAF9;strokeColor=#1565C0;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="170" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="inst-del-btn" value="&lt;b&gt;删除实例&lt;/b&gt;&lt;br&gt;从 instances[] 移除" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="175" width="180" height="40" as="geometry" />
