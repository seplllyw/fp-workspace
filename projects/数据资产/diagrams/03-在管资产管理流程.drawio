          <mxGeometry x="760" y="555" width="630" height="460" as="geometry" />
        </mxCell>
        <mxCell id="inst-tab-ledger-label" value="Tab 2: 基本信息 (台账)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="776" y="563" width="230" height="18" as="geometry" />
        </mxCell>

        <!-- Ledger Fields -->
        <mxCell id="ledger-basic" value="&lt;b&gt;基础字段&lt;/b&gt;&lt;br&gt;• 资产编码 (自动生成)&lt;br&gt;• 资产名称&lt;br&gt;• 桩号范围 (Kxxx+xxx ~ Kxxx+xxx)&lt;br&gt;• 管理单位&lt;br&gt;• 创建时间" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FFA000;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="780" y="592" width="260" height="125" as="geometry" />
        </mxCell>

        <mxCell id="ledger-custom" value="&lt;b&gt;自定义台账字段&lt;/b&gt;&lt;br&gt;renderInstanceLedgerFields()&lt;br&gt;继承模板 ledgerFields 定义&lt;br&gt;• 文本/数字/单选/多选&lt;br&gt;• 按模板配置动态渲染表单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FFA000;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="1080" y="592" width="280" height="125" as="geometry" />
        </mxCell>

        <!-- Priority Strip -->
