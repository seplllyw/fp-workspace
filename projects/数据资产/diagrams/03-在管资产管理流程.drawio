          <mxGeometry x="80" y="270" width="1340" height="200" as="geometry" />
        </mxCell>
        <mxCell id="wizard-label" value="新建资产向导 (openAddInstanceWizard)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="100" y="278" width="400" height="22" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="wiz-s1" value="&lt;b&gt;Step 1&lt;/b&gt;&lt;br&gt;选择资产模版&lt;br&gt;从 templates[] 列表选择" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FFA000;fontSize=10;" vertex="1" parent="1">
