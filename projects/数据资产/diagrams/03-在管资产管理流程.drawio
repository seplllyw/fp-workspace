          <mxGeometry x="100" y="78" width="550" height="22" as="geometry" />
        </mxCell>

        <!-- Filter Tabs -->
        <mxCell id="filter-tabs" value="&lt;b&gt;类型筛选 Tab&lt;/b&gt;&lt;br&gt;全部 | 桥梁 | 边坡 | 交安设施 | 隧道 | 地灾 | 服务设施 | 避险车道&lt;br&gt;instanceTemplateFilter 变量控制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="110" y="110" width="700" height="50" as="geometry" />
        </mxCell>

        <!-- Instance Table -->
        <mxCell id="inst-table" value="&lt;b&gt;实例列表表格&lt;/b&gt;&lt;br&gt;renderInstanceTable()&lt;br&gt;显示: 编码 | 名称 | 桩号 | 模板类型 | 状态 | 操作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="110" y="175" width="380" height="45" as="geometry" />
        </mxCell>

        <!-- Action Buttons -->
        <mxCell id="inst-new-btn" value="&lt;b&gt;新建资产&lt;/b&gt;&lt;br&gt;openAddInstanceWizard()&lt;br&gt;选择模板 → 填写台账 → 生成结构树" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=10;fontStyle=1;" vertex="1" parent="1">
