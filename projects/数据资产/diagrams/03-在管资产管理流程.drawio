          <mxGeometry x="350" y="315" width="210" height="65" as="geometry" />
        </mxCell>
        <mxCell id="wiz-arr2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FF9800;strokeWidth=1.5;" edge="1" parent="1" source="wiz-s2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="590" y="347" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 3 -->
        <mxCell id="wiz-s3" value="&lt;b&gt;Step 3&lt;/b&gt;&lt;br&gt;生成数字档案&lt;br&gt;基于模板树创建实例树&lt;br&gt;叶子节点可创建 unit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FFA000;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="315" width="210" height="65" as="geometry" />
        </mxCell>
        <mxCell id="wiz-arr3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FF9800;strokeWidth=1.5;" edge="1" parent="1" source="wiz-s3">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="347" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 4 -->
        <mxCell id="wiz-s4" value="&lt;b&gt;Step 4&lt;/b&gt;&lt;br&gt;确认创建&lt;br&gt;saveInstance() → instances[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;strokeColor=#E65100;fontSize=10;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="315" width="200" height="65" as="geometry" />
        </mxCell>

        <!-- Wizard note -->
        <mxCell id="wiz-note" value="&lt;b&gt;编码规则&lt;/b&gt;：新建时自动按模板 encodingRule 生成实体编码 (entityCode)&lt;br&gt;&lt;b&gt;结构树&lt;/b&gt;：实例树深度复制模板树结构，unitGroup 节点下可创建 unit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FFB300;fontSize=10;dashed=1;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="110" y="405" width="1100" height="40" as="geometry" />
        </mxCell>

        <!-- ====== INSTANCE EDIT PAGE ====== -->
        <mxCell id="inst-edit-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="1340" height="530" as="geometry" />
        </mxCell>
        <mxCell id="inst-edit-label" value="页面：实例编辑 (page-instance-edit) · switchInstanceTab()" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="100" y="518" width="500" height="22" as="geometry" />
