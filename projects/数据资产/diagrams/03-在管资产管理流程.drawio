        <!-- Tab 1: Digital Archive (Structure) -->
        <mxCell id="inst-tab-struct-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="110" y="555" width="620" height="460" as="geometry" />
        </mxCell>
        <mxCell id="inst-tab-struct-label" value="Tab 1: 数字档案 (结构) · renderInstanceStructureTree()" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="126" y="563" width="450" height="18" as="geometry" />
        </mxCell>

        <!-- Instance Tree -->
        <mxCell id="inst-tree" value="&lt;b&gt;实例结构树 (左右分栏)&lt;/b&gt;&lt;br&gt;• 基于模板树实例化&lt;br&gt;• 显示 unitGroup 节点&lt;br&gt;• 点击节点查看详情&lt;br&gt;• addInstanceTreeNode() 创建unit&lt;br&gt;• copyTemplateBranch / pasteTemplateBranchAsChild" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="130" y="592" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- Unit Management -->
        <mxCell id="unit-mgmt" value="&lt;b&gt;最小维护单元 (Unit) 管理&lt;/b&gt;&lt;br&gt;unitGroup 节点下通过 "+" 创建&lt;br&gt;• unitCounts: 单元计数&lt;br&gt;• unitData: 位置描述/状态/备注&lt;br&gt;• unitDefects: 病害绑定&lt;br&gt;• unitFlightArchives: 飞行巡检档案&lt;br&gt;例: "左幅 1#墩", "2#墩"..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#90CAF9;strokeColor=#1565C0;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="130" y="730" width="280" height="130" as="geometry" />
        </mxCell>

        <!-- Inspection Sub-view -->
        <mxCell id="inspection-sub" value="&lt;b&gt;巡检记录子视图&lt;/b&gt;&lt;br&gt;instanceStructureSubview = 'inspection'&lt;br&gt;• hasInspectionData() 判断有无数据&lt;br&gt;• renderInspectionOverviewPanel()&lt;br&gt;• renderStructureInspectionHub()&lt;br&gt;  - 结构树中标记巡检状态&lt;br&gt;• jumpToInspectionUnit() 跳转定位" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=9;align=left;spacingLeft=6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="130" y="880" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- Right: Node Detail -->
        <mxCell id="inst-node-detail" value="&lt;b&gt;节点详情面板&lt;/b&gt;&lt;br&gt;renderInstanceNodeDetail()&lt;br&gt;• 节点基本信息&lt;br&gt;• Unit 列表 (含操作按钮)&lt;br&gt;• Unit 详情编辑&lt;br&gt;• 病害记录展示&lt;br&gt;• 飞行档案展示" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=9;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="450" y="592" width="260" height="140" as="geometry" />
        </mxCell>

