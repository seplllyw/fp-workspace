        <!-- DEFECT_POOL -->
        <mxCell id="defect-pool" value="&lt;b&gt;DEFECT_POOL[] 病害库&lt;/b&gt;&lt;br&gt;• id: d1-d8 (demo保留) + br-d001+ (巡检文档提取)&lt;br&gt;• name: 病害名称&lt;br&gt;• code: 病害编码 (缩写)&lt;br&gt;• level: 等级 1-3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C2185B;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
